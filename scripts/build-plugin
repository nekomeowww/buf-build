#!/usr/bin/env bash
set -euo pipefail

tag="${1:-}"
if [[ -z "${tag}" ]]; then
  echo "usage: $0 <family-plugin/version>" >&2
  exit 64
fi

eval "$(scripts/tag-env "${tag}")"

platform="${PLATFORM:-$(scripts/host-platform)}"

docker buildx build \
  --platform "${platform}" \
  -f "${DOCKERFILE}" \
  "${UPSTREAM_DIR}" \
  --tag "${IMAGE}" \
  --load

docker image inspect "${IMAGE}" >/dev/null
docker run --rm --platform "${platform}" "${IMAGE}" --version >/dev/null || true
