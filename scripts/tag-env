#!/usr/bin/env bash
set -euo pipefail

tag="${1:-}"

if [[ -z "${tag}" ]]; then
  tag="$(git describe --tags --exact-match 2>/dev/null || true)"
fi

if [[ -z "${tag}" || "${tag}" != */* ]]; then
  echo "usage: $0 <family-plugin/version>" >&2
  echo "example: $0 protocolbuffers-go/v1.36.10" >&2
  exit 64
fi

plugin="${tag%%/*}"
version="${tag#*/}"
family="${plugin%%-*}"
name="${plugin#*-}"

if [[ "${family}" == "${plugin}" || -z "${name}" || -z "${version}" ]]; then
  echo "invalid tag: ${tag}" >&2
  echo "expected: <family>-<plugin>/<version>" >&2
  exit 64
fi

upstream_dir="upstream/bufbuild-plugins/plugins/${family}/${name}/${version}"
dockerfile="${upstream_dir}/Dockerfile"
image="ghcr.io/nekomeowww/buf-build/${plugin}:${version}"

if [[ ! -f "${dockerfile}" ]]; then
  echo "missing upstream Dockerfile: ${dockerfile}" >&2
  exit 66
fi

printf 'TAG=%q\n' "${tag}"
printf 'PLUGIN=%q\n' "${plugin}"
printf 'VERSION=%q\n' "${version}"
printf 'FAMILY=%q\n' "${family}"
printf 'NAME=%q\n' "${name}"
printf 'UPSTREAM_DIR=%q\n' "${upstream_dir}"
printf 'DOCKERFILE=%q\n' "${dockerfile}"
printf 'IMAGE=%q\n' "${image}"
