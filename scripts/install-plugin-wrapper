#!/usr/bin/env bash
set -euo pipefail

image="${1:-}"
out_dir="${2:-.tools/protoc-plugins}"
platform="${PLATFORM:-$(scripts/host-platform)}"

if [[ -z "${image}" ]]; then
  echo "usage: $0 <image> [out-dir]" >&2
  echo "example: $0 ghcr.io/nekomeowww/buf-build/protocolbuffers-go:v1.36.10 .tools/protoc-plugins" >&2
  exit 64
fi

docker pull --platform "${platform}" "${image}" >/dev/null

entrypoint="$(docker image inspect "${image}" --format '{{ index .Config.Entrypoint 0 }}')"
if [[ -z "${entrypoint}" || "${entrypoint}" == "<no value>" ]]; then
  echo "image has no entrypoint: ${image}" >&2
  exit 65
fi

binary="$(basename "${entrypoint}")"
wrapper="${out_dir}/${binary}"
mkdir -p "${out_dir}"

cat > "${wrapper}" <<EOF
#!/usr/bin/env bash
set -euo pipefail

exec docker run --rm -i --platform "${platform}" "${image}" "\$@"
EOF

chmod +x "${wrapper}"
printf '%s\n' "${wrapper}"
